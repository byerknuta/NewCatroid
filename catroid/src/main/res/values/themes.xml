<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.NewCatroid.LibraryEditor" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <item name="colorPrimary">@color/toolbar_background</item>
        <item name="colorPrimaryVariant">@color/toolbar_background</item>
        <item name="colorOnPrimary">@color/toolbar_title</item>


        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:textColor">@color/solid_white</item>


        <item name="colorAccent">@color/accent</item>
        <item name="colorSecondary">@color/accent</item>


        <item name="toolbarStyle">@style/Widget.NewCatroid.Toolbar</item>
        <item name="tabStyle">@style/Widget.NewCatroid.TabLayout</item>
        <item name="materialCardViewStyle">@style/Widget.NewCatroid.CardView</item>
        <item name="textInputStyle">@style/Widget.NewCatroid.TextInputLayout</item>
        <item name="alertDialogTheme">@style/Theme.NewCatroid.Dialog</item>
    </style>


    <style name="Widget.NewCatroid.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/toolbar_background</item>
        <item name="titleTextColor">@color/toolbar_title</item>
    </style>

    <style name="Widget.NewCatroid.TabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="android:background">@color/toolbar_background</item>
        <item name="tabIndicatorColor">@color/accent</item>
        <item name="tabTextColor">@color/spinner_icon_and_inactive_elements</item>
        <item name="tabSelectedTextColor">@color/solid_white</item>
    </style>

    <style name="Widget.NewCatroid.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/button_background</item>
    </style>

    <style name="Widget.NewCatroid.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:textColorHint">@color/spinner_icon_and_inactive_elements</item>
        <item name="boxStrokeColor">@color/accent</item>
        <item name="hintTextColor">@color/accent</item>
    </style>


    <style name="Theme.NewCatroid.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:colorBackground">@color/surface_card</item>
        <item name="android:textColor">@color/solid_white</item>
        <item name="android:textColorPrimary">@color/solid_white</item>
        <item name="android:textColorSecondary">@color/spinner_icon_and_inactive_elements</item>
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="colorAccent">@color/accent</item>

        <item name="colorSurface">@color/surface_card</item>

        <item name="backgroundTint">@color/surface_card</item>
        <item name="android:backgroundTint">@color/surface_card</item>

        <item name="boxBackgroundColor">@color/app_background</item>
        <item name="editTextStyle">@style/BrickEditText</item>

        <item name="colorPrimary">@color/accent</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorControlActivated">@color/accent</item>

        <item name="buttonBarPositiveButtonStyle">@style/Widget.NewCatroid.DialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.NewCatroid.DialogButton</item>
        <item name="android:textColorHint">@color/spinner_icon_and_inactive_elements</item>
        <item name="android:editTextColor">@color/solid_white</item>

        <item name="textColorAlertDialogListItem">@color/solid_white</item>
        <item name="android:textColorAlertDialogListItem">@color/solid_white</item>
    </style>

    <style name="Widget.NewCatroid.DialogButton" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/accent</item>
    </style>

    <style name="Theme.PaintroidFix" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/pocketpaint_color_picker_purple1</item>
        <item name="colorPrimaryVariant">@color/pocketpaint_color_picker_purple2</item>
        <item name="colorOnPrimary">@color/white</item>
    </style>

    <style name="InspectorHeader" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="InspectorLabel" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textColor">#CCCCCC</item>
        <item name="android:layout_marginTop">8dp</item>
    </style>

    <style name="InspectorEditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textColorHint">#888888</item>
        <item name="android:backgroundTint">#AAAAAA</item>
    </style>

    <style name="InspectorSpinner" parent="Widget.AppCompat.Spinner">
        <item name="android:backgroundTint">#AAAAAA</item>

    </style>

    <style name="ShapeAppearance.NewCatroid.FAB" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="Theme.NewCatroid.Stage" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@color/app_background</item>

        <item name="colorPrimary">@color/toolbar_background</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:textColor">@color/solid_white</item>

        <item name="editTextStyle">@style/BrickEditText</item>
        <item name="colorControlActivated">@color/accent</item>
    </style>

</resources>
