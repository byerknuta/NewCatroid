<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <TextView style="@style/InspectorLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/editor_3d_phys_state" android:layout_marginTop="8dp"/>
    <Spinner android:id="@+id/spinner_physics_state" style="@style/InspectorSpinner" android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="4dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/separator"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:id="@+id/colliders_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <Button
        android:id="@+id/btn_add_box_collider"
        style="@style/Widget.App.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/editor_3d_phys_add_box" />

    <Button
        android:id="@+id/btn_add_capsule_collider"
        style="@style/Widget.App.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/editor_3d_phys_add_capsule" />

    <LinearLayout android:id="@+id/layout_physics_mass" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView style="@style/InspectorLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/editor_3d_phys_mass" android:layout_marginTop="8dp"/>
        <EditText android:id="@+id/edit_physics_mass" style="@style/InspectorEditText" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:layout_marginTop="4dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/layout_physics_properties" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView style="@style/InspectorLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/editor_3d_phys_friction" android:layout_marginTop="8dp"/>
        <EditText android:id="@+id/edit_physics_friction" style="@style/InspectorEditText" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:layout_marginTop="4dp"/>

        <TextView style="@style/InspectorLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/editor_3d_phys_restitution" android:layout_marginTop="8dp"/>
        <EditText android:id="@+id/edit_physics_restitution" style="@style/InspectorEditText" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" android:layout_marginTop="4dp"/>
    </LinearLayout>

</LinearLayout>
