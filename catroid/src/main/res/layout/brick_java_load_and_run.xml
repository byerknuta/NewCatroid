<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_java_load_layout"
        style="@style/BrickContainer.Device.Big">

        <include layout="@layout/icon_brick_category_file" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_java_load_title" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_java_load_path"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_java_load_path_field"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_java_load_class"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_java_load_class_field"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_java_load_method"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_java_load_method_field"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_java_load_arg"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_java_load_arg_field"
            style="@style/BrickEditText" />

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>
