<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">

    <CheckBox android:id="@+id/brick_checkbox" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout android:id="@+id/brick_layout" style="@style/BrickContainer.Device.Big">
        <include layout="@layout/icon_brick_category_device" />
        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_create_text_label_title" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_create_text_label_id" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_id_field" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_create_text_label_text" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_text_field" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_create_text_label_color" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_color_field" style="@style/BrickEditText" />
        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_create_text_label_size" />
        <TextView android:id="@+id/brick_size_field" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_create_text_label_bg" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_bg_field" style="@style/BrickEditText" />
        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_create_text_label_radius" />
        <TextView android:id="@+id/brick_radius_field" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_create_text_label_font" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_font_field" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_create_text_label_spacing" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_spacing_field" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_create_text_label_format" app:layout_newLine="true"/>
        <Spinner android:id="@+id/brick_format_spinner" android:layout_width="wrap_content" android:layout_height="wrap_content" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_create_text_label_align" app:layout_newLine="true"/>
        <Spinner android:id="@+id/brick_align_spinner" android:layout_width="wrap_content" android:layout_height="wrap_content" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_create_text_label_scroll" app:layout_newLine="true"/>
        <Spinner android:id="@+id/brick_scroll_spinner" android:layout_width="wrap_content" android:layout_height="wrap_content" />

        <TextView style="@style/BrickText.SingleLine" android:text="X: " app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_x_field" style="@style/BrickEditText" />
        <TextView style="@style/BrickText.SingleLine" android:text=" Y: " />
        <TextView android:id="@+id/brick_y_field" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="W: " app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_w_field" style="@style/BrickEditText" />
        <TextView style="@style/BrickText.SingleLine" android:text=" H: " />
        <TextView android:id="@+id/brick_h_field" style="@style/BrickEditText" />
    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>
