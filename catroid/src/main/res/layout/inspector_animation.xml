<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_inspector_card">

    <TextView
        style="@style/InspectorLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/editor_3d_anim_clip" />
    <Spinner
        android:id="@+id/spinner_animations"
        style="@style/InspectorSpinner"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="4dp"/>

    <TextView
        style="@style/InspectorLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/editor_3d_anim_speed" />
    <EditText
        android:id="@+id/edit_anim_speed"
        style="@style/InspectorEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:inputType="numberDecimal"
        android:text="1.0"/>

    <TextView
        style="@style/InspectorLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/editor_3d_anim_transition" />
    <EditText
        android:id="@+id/edit_anim_transition"
        style="@style/InspectorEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:inputType="numberDecimal"
        android:text="0.2"/>

    <CheckBox
        android:id="@+id/checkbox_anim_loop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/solid_white"
        android:buttonTint="@color/accent"
        android:text="@string/editor_3d_anim_loop"/>
</LinearLayout>
