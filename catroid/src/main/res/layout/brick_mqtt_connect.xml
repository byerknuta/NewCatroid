<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_mqtt_connect_layout"
        style="@style/BrickContainer.Internet.Big">

        <include layout="@layout/icon_brick_category_internet" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_mqtt_connect_title" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_mqtt_connect_id"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_mqtt_connect_id"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_mqtt_connect_host"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_mqtt_connect_host"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_mqtt_connect_port"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_mqtt_connect_port"
            style="@style/BrickEditText" />

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>
