<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
    <CheckBox android:id="@+id/brick_checkbox" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
    <org.catrobat.catroid.ui.BrickLayout android:id="@+id/brick_notification_show_layout" style="@style/BrickContainer.Device.Medium">
        <include layout="@layout/icon_brick_category_device" />
        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_notification_show_title" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_notification_id" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_notif_show_id" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_notification_show_delay" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_notif_show_delay" style="@style/BrickEditText" />
    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>
