<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_script"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical" >

    <org.catrobat.catroid.ui.ScriptFinder
        android:id="@+id/findview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <org.catrobat.catroid.ui.dragndrop.BrickListView
            android:id="@android:id/list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:divider="@android:color/transparent"
            android:dividerHeight="@dimen/script_spacing" />

        <RelativeLayout
            android:id="@android:id/empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent" >

            <TextView
                android:id="@+id/fragment_script_text_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:text="@string/fragment_script_text_description"
                android:textSize="?attr/x_large" />
        </RelativeLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/analysis_status_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:visibility="gone"
            app:cardCornerRadius="14dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface_card"
            android:foreground="?android:attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/error_dot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@android:drawable/presence_online"
                    android:layout_marginRight="4dp"
                    app:tint="@color/red" />

                <TextView
                    android:id="@+id/error_count_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/red"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:text="0"
                    android:layout_marginRight="10dp"/>

                <ImageView
                    android:id="@+id/warning_dot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@android:drawable/presence_online"
                    android:layout_marginRight="4dp"
                    app:tint="@color/orange" />

                <TextView
                    android:id="@+id/warning_count_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/orange"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:text="0" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </FrameLayout>
</LinearLayout>
