<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/surface_card"
    app:cardCornerRadius="28dp"
    app:cardElevation="12dp"
    app:strokeColor="@color/accent"
    app:strokeWidth="1.5dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp"
                android:text="@string/community_publish_title"
                android:textColor="@color/view_holder_item_title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPublishTitle"
                style="@style/Widget.NewCatroid.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:hint="@string/project_name_label">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPublishTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/solid_white"
                    android:inputType="textNoSuggestions" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPublishDescription"
                style="@style/Widget.NewCatroid.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/community_publish_desc_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPublishDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/solid_white"
                    android:gravity="top"
                    android:minLines="3"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tvPublishRulesLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:text="@string/community_publish_rules_link"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:textStyle="bold|italic" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="@string/community_publish_genres"
                android:textColor="@color/view_holder_item_title"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupPublishGenres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitPublish"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/community_publish_start"
                android:textColor="@color/app_background_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/accent"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>
</com.google.android.material.card.MaterialCardView>
