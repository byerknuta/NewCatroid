<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:strokeColor="@color/accent"
    app:strokeWidth="1.5dp"
    app:cardBackgroundColor="@color/surface_card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/apk_builder_title"
            android:textColor="@color/solid_white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvStepSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvDialogTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <ProgressBar
            android:id="@+id/stepProgressIndicator"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="12dp"
            android:max="100"
            android:progress="25"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="#22A8DFF4"
            app:layout_constraintTop_toBottomOf="@id/tvStepSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintHeight_default="wrap"
            app:layout_constraintHeight_max="380dp"
            app:layout_constraintTop_toBottomOf="@id/stepProgressIndicator"
            app:layout_constraintBottom_toTopOf="@id/buttonDivider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fillViewport="true">

            <FrameLayout
                android:id="@+id/stepsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/step1Container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilAppName"
                        style="@style/Widget.NewCatroid.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="@string/build_app_name">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBuildAppName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPackageName"
                        style="@style/Widget.NewCatroid.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="@string/build_package_name">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBuildPackageName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilVersionName"
                            style="@style/Widget.NewCatroid.TextInputLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:hint="@string/build_version_name">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etBuildVersionName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/solid_white" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilVersionCode"
                            style="@style/Widget.NewCatroid.TextInputLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:hint="@string/build_version_code">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etBuildVersionCode"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textColor="@color/solid_white" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilTemplates"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxStrokeColor="@color/accent"
                        app:hintTextColor="@color/accent"
                        android:hint="@string/build_template">
                        <AutoCompleteTextView
                            android:id="@+id/etBuildTemplate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/solid_white" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent"
                        android:text="@string/build_orientation"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleGroupOrientation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        app:singleSelection="true"
                        app:checkedButton="@+id/btnPortrait">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPortrait"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/solid_white"
                            app:strokeColor="@color/accent"
                            android:text="@string/orientation_portrait" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLandscape"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/solid_white"
                            app:strokeColor="@color/accent"
                            android:text="@string/orientation_landscape" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSensor"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/solid_white"
                            app:strokeColor="@color/accent"
                            android:text="@string/orientation_sensor" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/step2Container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent"
                        android:text="@string/build_modules_title"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchPython"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/solid_white"
                        android:text="@string/lib_python_engine" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchQemu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/solid_white"
                        android:text="@string/lib_qemu_vm" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchCompiler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/solid_white"
                        android:text="@string/lib_compiler" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchMkit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/solid_white"
                        android:text="@string/lib_ml_kit" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchOnnx"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/solid_white"
                        android:text="@string/lib_onnx" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchMnn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:textColor="@color/solid_white"
                        android:text="@string/lib_mnn" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent"
                        android:text="@string/build_cpu_archs"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <CheckBox
                        android:id="@+id/cbArm64"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:textColor="@color/solid_white"
                        android:text="@string/arch_arm64" />

                    <CheckBox
                        android:id="@+id/cbArmv7"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:textColor="@color/solid_white"
                        android:text="@string/arch_armv7" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/step3Container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent"
                        android:text="@string/build_permissions_title"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:strokeColor="@color/accent"
                        app:strokeWidth="1dp"
                        app:cardBackgroundColor="@color/button_background">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/perm_auto_recommended"
                                android:textColor="@color/accent"
                                android:textStyle="bold"
                                android:textSize="13sp" />

                            <com.google.android.material.chip.ChipGroup
                                android:id="@+id/cgDetectedPermissions"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchCustomizePermissions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/solid_white"
                        android:layout_marginBottom="4dp"
                        android:text="@string/perm_customize_manually" />

                    <LinearLayout
                        android:id="@+id/llManualPermissions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchPermInternet"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white"
                            android:text="@string/perm_internet" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchPermStorage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white"
                            android:text="@string/perm_storage" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchPermCamera"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white"
                            android:text="@string/perm_camera" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchPermAudio"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white"
                            android:text="@string/perm_audio" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchPermLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white"
                            android:text="@string/perm_location" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchPermBluetooth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white"
                            android:text="@string/perm_bluetooth" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchPermNfc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white"
                            android:text="@string/perm_nfc" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchPermVibrate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white"
                            android:text="@string/perm_vibrate" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchPermOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white"
                            android:text="@string/perm_overlay" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchPermBackground"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white"
                            android:text="@string/perm_background" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/step4Container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent"
                        android:text="@string/build_signature_title"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <RadioGroup
                        android:id="@+id/rgKeystore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">

                        <RadioButton
                            android:id="@+id/rbAutoDebug"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:textColor="@color/solid_white"
                            android:text="@string/build_auto_debug" />

                        <RadioButton
                            android:id="@+id/rbGenerateNew"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white"
                            android:text="@string/build_generate_new_title" />

                        <RadioButton
                            android:id="@+id/rbCustomKeystore"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/solid_white"
                            android:text="@string/build_custom_keystore" />
                    </RadioGroup>

                    <LinearLayout
                        android:id="@+id/llGenerateKeystoreFields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.NewCatroid.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:hint="@string/build_gen_alias">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etGenAlias"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/solid_white" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.NewCatroid.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:hint="@string/build_gen_pass">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etGenPass"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword"
                                android:textColor="@color/solid_white" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.NewCatroid.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="@string/build_gen_owner">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etGenOwner"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/solid_white" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGenerateAndExportKeystore"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:strokeColor="@color/accent"
                            android:textColor="@color/accent"
                            android:text="@string/build_btn_generate_save" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/llCustomKeystoreFields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSelectKeystore"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:strokeColor="@color/accent"
                            android:textColor="@color/accent"
                            android:layout_marginBottom="8dp"
                            android:text="@string/build_select_keystore" />

                        <TextView
                            android:id="@+id/tvSelectedKeystorePath"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:text="@string/no_file_selected" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.NewCatroid.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:hint="@string/build_key_alias">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etKeystoreAlias"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/solid_white" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.NewCatroid.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/build_key_pass">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etKeystorePass"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword"
                                android:textColor="@color/solid_white" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>
        </androidx.core.widget.NestedScrollView>

        <View
            android:id="@+id/buttonDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/separator"
            android:layout_marginBottom="12dp"
            app:layout_constraintBottom_toTopOf="@id/navigationContainer" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/navigationContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cancel"
                android:textColor="@color/text_secondary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_back"
                android:textColor="@color/accent"
                android:visibility="invisible"
                app:layout_constraintEnd_toStartOf="@id/btnNext"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_next"
                app:backgroundTint="@color/accent"
                android:textColor="@color/app_background_dark"
                app:rippleColor="@color/solid_white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
