<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background_dark">

    <WebView
        android:id="@+id/webView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/warningNotificationCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="24dp"
        app:cardElevation="10dp"
        app:strokeColor="@color/red"
        app:strokeWidth="1.5dp"
        app:layout_constraintWidth_max="350dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_pocketpaint_dialog_warning"
                app:tint="@color/red"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvWarningText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/community_download_already_active"
                android:textColor="@color/solid_white"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/downloadNotificationCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:strokeColor="@color/accent"
        app:strokeWidth="1.5dp"
        app:layout_constraintWidth_percent="0.95"
        app:layout_constraintWidth_max="450dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp">

            <ProgressBar
                android:id="@+id/notificationProgressBar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:indeterminate="true"
                android:progressTint="@color/accent"
                android:indeterminateTint="@color/accent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <LinearLayout
                android:id="@+id/textContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                app:layout_constraintStart_toEndOf="@id/notificationProgressBar"
                app:layout_constraintEnd_toStartOf="@id/btnOpenProject"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/tvNotificationTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/community_download_title"
                    android:textColor="@color/view_holder_item_title"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNotificationStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/community_downloading_files"
                    android:textColor="@color/solid_white"
                    android:textSize="12sp"
                    android:ellipsize="end"
                    android:maxLines="1" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenProject"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/community_open_btn"
                android:textColor="@color/app_background_dark"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="gone"
                app:backgroundTint="@color/accent"
                app:cornerRadius="18dp"
                app:layout_constraintEnd_toStartOf="@id/btnDismissNotification"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageButton
                android:id="@+id/btnDismissNotification"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/solid_white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
