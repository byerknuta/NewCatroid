<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_layout"
        style="@style/BrickContainer.Threed.Big">

        <include layout="@layout/icon_brick_category_threed" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_threed_fixed_joint_title" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_threed_fixed_joint_id"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_fixed_joint_id"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_threed_fixed_joint_obj_a"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_fixed_joint_a"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_threed_fixed_joint_obj_b"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_fixed_joint_b"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_threed_fixed_joint_mode"
            app:layout_newLine="true"/>
        <Spinner
            android:id="@+id/brick_fixed_joint_spinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/brick_fixed_joint_manual_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_newLine="true">

            <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_threed_fixed_joint_pivot_a" />
                <TextView android:id="@+id/brick_fixed_joint_ax" style="@style/BrickEditText" />
                <TextView android:id="@+id/brick_fixed_joint_ay" style="@style/BrickEditText" />
                <TextView android:id="@+id/brick_fixed_joint_az" style="@style/BrickEditText" />
            </LinearLayout>

            <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_threed_fixed_joint_pivot_b" />
                <TextView android:id="@+id/brick_fixed_joint_bx" style="@style/BrickEditText" />
                <TextView android:id="@+id/brick_fixed_joint_by" style="@style/BrickEditText" />
                <TextView android:id="@+id/brick_fixed_joint_bz" style="@style/BrickEditText" />
            </LinearLayout>
        </LinearLayout>

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>