<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_pt_embedding_layout"
        style="@style/BrickContainer.Pocketensor.Big">

        <include layout="@layout/icon_brick_category_pocketensor" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_layer_embedding" />

        <TextView
            android:id="@+id/brick_pt_emb_name"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_layer_linear_in"
            app:layout_newLine="true" />

        <TextView
            android:id="@+id/brick_pt_emb_input"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_layer_linear_out"
            app:layout_newLine="true" />

        <TextView
            android:id="@+id/brick_pt_emb_output"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_emb_vocab"
            app:layout_newLine="true" />

        <TextView
            android:id="@+id/brick_pt_emb_vocab"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_emb_dim"
            app:layout_newLine="true" />

        <TextView
            android:id="@+id/brick_pt_emb_dim"
            style="@style/BrickEditText" />

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>
