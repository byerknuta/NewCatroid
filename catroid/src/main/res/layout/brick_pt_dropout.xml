<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_pt_dropout_layout"
        style="@style/BrickContainer.Pocketensor.Medium">

        <include layout="@layout/icon_brick_category_pocketensor" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_dropout_res" />

        <TextView
            android:id="@+id/brick_pt_drop_res"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_slice_input"
            app:layout_newLine="true" />

        <TextView
            android:id="@+id/brick_pt_drop_input"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_drop_prob"
            app:layout_newLine="true" />

        <TextView
            android:id="@+id/brick_pt_drop_prob"
            style="@style/BrickEditText" />

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>
