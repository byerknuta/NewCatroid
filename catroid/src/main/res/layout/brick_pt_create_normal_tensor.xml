<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_pt_create_normal_layout"
        style="@style/BrickContainer.Pocketensor.Big">

        <include layout="@layout/icon_brick_category_pocketensor" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_create_normal_tensor" />

        <TextView
            android:id="@+id/brick_pt_normal_name"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_tensor_shape"
            app:layout_newLine="true" />

        <TextView
            android:id="@+id/brick_pt_normal_shape"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_tensor_mean"
            app:layout_newLine="true" />

        <TextView
            android:id="@+id/brick_pt_normal_mean"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_tensor_std" />

        <TextView
            android:id="@+id/brick_pt_normal_std"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_tensor_trainable"
            app:layout_newLine="true" />

        <TextView
            android:id="@+id/brick_pt_normal_trainable"
            style="@style/BrickEditText" />

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>
