<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_http_body_layout"
        style="@style/BrickContainer.Internet.Big">

        <include layout="@layout/icon_brick_category_data" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_http_body_title" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_http_body_id"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_http_body_id_field"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_http_body_text"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_http_body_text_field"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_http_body_content_type"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_http_body_content_type_field"
            style="@style/BrickEditText" />

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>
