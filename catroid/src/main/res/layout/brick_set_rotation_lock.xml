<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_rotation_lock_layout"
        style="@style/BrickContainer.Threed.Small">

        <include layout="@layout/icon_brick_category_threed" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_rotation_lock_title" />

        <TextView
            android:id="@+id/brick_rotation_lock_object_id"
            style="@style/BrickEditText"
            android:layout_marginLeft="8dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_newLine="true"
            android:gravity="center_vertical">

            <TextView
                style="@style/BrickText.SingleLine"
                android:text="@string/brick_rotation_lock_axes" />

            <CheckBox
                android:id="@+id/brick_rotation_lock_x"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X"
                android:buttonTint="#FFFFFF"
                android:textColor="#FFFFFF"/>

            <CheckBox
                android:id="@+id/brick_rotation_lock_y"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Y"
                android:buttonTint="#FFFFFF"
                android:textColor="#FFFFFF"/>

            <CheckBox
                android:id="@+id/brick_rotation_lock_z"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Z"
                android:buttonTint="#FFFFFF"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>