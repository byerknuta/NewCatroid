<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_align_position_with_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_mylocation"
            app:tint="@color/solid_white"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <ImageButton
            android:id="@+id/btn_align_rotation_with_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_rotate"
            app:tint="@color/solid_white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Position -->
    <TextView style="@style/InspectorLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/editor_3d_position" android:layout_marginTop="8dp"/>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="X" android:textColor="@color/accent" android:layout_marginEnd="4dp" android:layout_gravity="center_vertical"/>
        <EditText android:id="@+id/edit_pos_x" style="@style/InspectorEditText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:inputType="numberDecimal|numberSigned"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Y" android:textColor="@color/accent" android:layout_marginHorizontal="4dp" android:layout_gravity="center_vertical"/>
        <EditText android:id="@+id/edit_pos_y" style="@style/InspectorEditText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:inputType="numberDecimal|numberSigned"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Z" android:textColor="@color/accent" android:layout_marginHorizontal="4dp" android:layout_gravity="center_vertical"/>
        <EditText android:id="@+id/edit_pos_z" style="@style/InspectorEditText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:inputType="numberDecimal|numberSigned"/>
    </LinearLayout>

    <!-- Rotation -->
    <TextView style="@style/InspectorLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/editor_3d_rotation" android:layout_marginTop="8dp"/>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="X" android:textColor="@color/accent" android:layout_marginEnd="4dp" android:layout_gravity="center_vertical"/>
        <EditText android:id="@+id/edit_rot_x" style="@style/InspectorEditText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:inputType="numberDecimal|numberSigned"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Y" android:textColor="@color/accent" android:layout_marginHorizontal="4dp" android:layout_gravity="center_vertical"/>
        <EditText android:id="@+id/edit_rot_y" style="@style/InspectorEditText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:inputType="numberDecimal|numberSigned"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Z" android:textColor="@color/accent" android:layout_marginHorizontal="4dp" android:layout_gravity="center_vertical"/>
        <EditText android:id="@+id/edit_rot_z" style="@style/InspectorEditText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:inputType="numberDecimal|numberSigned"/>
    </LinearLayout>

    <!-- Scale -->
    <TextView style="@style/InspectorLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/editor_3d_scale" android:layout_marginTop="8dp"/>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="X" android:textColor="@color/accent" android:layout_marginEnd="4dp" android:layout_gravity="center_vertical"/>
        <EditText android:id="@+id/edit_scale_x" style="@style/InspectorEditText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:inputType="numberDecimal"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Y" android:textColor="@color/accent" android:layout_marginHorizontal="4dp" android:layout_gravity="center_vertical"/>
        <EditText android:id="@+id/edit_scale_y" style="@style/InspectorEditText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:inputType="numberDecimal"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Z" android:textColor="@color/accent" android:layout_marginHorizontal="4dp" android:layout_gravity="center_vertical"/>
        <EditText android:id="@+id/edit_scale_z" style="@style/InspectorEditText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:inputType="numberDecimal"/>
    </LinearLayout>

</LinearLayout>
