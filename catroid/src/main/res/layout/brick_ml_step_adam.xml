<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox android:id="@+id/brick_checkbox" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_ml_step_adam_layout"
        style="@style/BrickContainer.Pocketensor.Medium">

        <include layout="@layout/icon_brick_category_pocketensor" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_ml_step_adam" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_ml_lr" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_ml_edit_lr" style="@style/BrickEditText" />
    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>