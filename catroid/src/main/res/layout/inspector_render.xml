<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_inspector_card">

    <TextView
        style="@style/InspectorLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/editor_3d_model_file"/>

    <TextView
        android:id="@+id/text_model_path"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_inspector_input"
        android:textColor="@color/solid_white"
        android:textSize="14sp"
        android:text="@string/editor_3d_no_model_selected"/>

    <Button
        android:id="@+id/btn_select_model"
        style="@style/Widget.AppCompat.Button.Colored"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:backgroundTint="@color/accent"
        android:textColor="@color/app_background"
        android:text="@string/editor_3d_select_model"/>
</LinearLayout>
