<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_set_corner_offsets_layout"
        style="@style/BrickContainer.Look.Big">

        <include layout="@layout/icon_brick_category_look" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_set_corner_offsets_title" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_set_corner_offsets_top_left"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_set_corner_offsets_tlx"
            style="@style/BrickEditText" />
        <TextView
            android:id="@+id/brick_set_corner_offsets_tly"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_set_corner_offsets_top_right"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_set_corner_offsets_trx"
            style="@style/BrickEditText" />
        <TextView
            android:id="@+id/brick_set_corner_offsets_try"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_set_corner_offsets_bottom_right"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_set_corner_offsets_brx"
            style="@style/BrickEditText" />
        <TextView
            android:id="@+id/brick_set_corner_offsets_bry"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_set_corner_offsets_bottom_left"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_set_corner_offsets_blx"
            style="@style/BrickEditText" />
        <TextView
            android:id="@+id/brick_set_corner_offsets_bly"
            style="@style/BrickEditText" />

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>
