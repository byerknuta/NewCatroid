<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_http_config_layout"
        style="@style/BrickContainer.Internet.Big">

        <include layout="@layout/icon_brick_category_data" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_http_config_title" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_http_config_id"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_http_config_id_field"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_http_config_type"
            app:layout_newLine="true"/>
        <Spinner
            android:id="@+id/brick_http_config_type_spinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textDirection="locale" />

        <LinearLayout
            android:id="@+id/brick_http_config_key_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_newLine="true">
            <TextView
                style="@style/BrickText.SingleLine"
                android:text="@string/brick_http_config_key" />
            <TextView
                android:id="@+id/brick_http_config_key_field"
                style="@style/BrickEditText" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/brick_http_config_value_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_newLine="true">
            <TextView
                style="@style/BrickText.SingleLine"
                android:text="@string/brick_http_config_value" />
            <TextView
                android:id="@+id/brick_http_config_value_field"
                style="@style/BrickEditText" />
        </LinearLayout>

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>
