<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_pt_op_layout"
        style="@style/BrickContainer.Pocketensor.Big">

        <include layout="@layout/icon_brick_category_pocketensor" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_operation" />

        <Spinner
            android:id="@+id/brick_pt_op_spinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pt_res"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_pt_op_res"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="A:"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_pt_op_a"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="B:"
            app:layout_newLine="true"/>
        <TextView
            android:id="@+id/brick_pt_op_b"
            style="@style/BrickEditText" />

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>